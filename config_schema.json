{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "enabled":          { "type": "boolean", "default": true },
    "display_duration": { "type": "number",  "default": 30 },
    "update_interval":  { "type": "integer", "default": 15 },
    "live_priority":    { "type": "boolean", "default": false },
    "ha_url":           { "type": "string",  "default": "http://192.168.0.36:8123" },
    "ha_token":         { "type": "string",  "description": "HA long-lived access token" },
    "tmdb_token":       { "type": "string",  "description": "TMDB API Bearer token" },
    "fanart_api_key":   { "type": "string",  "description": "Fanart.tv API key" },
    "plex_entities":    { "type": "array",   "items": { "type": "string" } }
  }
}
